# Database
MONGO_URI=mongodb://localhost:27017/techyjaunt-db

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-complex

# ZeptoMail (Zoho) — https://www.npmjs.com/package/zeptomail
ZEPTOMAIL_API_URL=api.zeptomail.com/
ZEPTOMAIL_API_TOKEN=Zoho-enczapikey YOUR_SEND_MAIL_TOKEN_HERE
ZEPTOMAIL_FROM_ADDRESS=noreply@your-verified-domain.com
ZEPTOMAIL_FROM_NAME=TechyJaunt
# Optional fallback for from address
EMAIL_NODEMAILER=noreply@your-verified-domain.com
ADMIN_EMAIL=admin@techyjaunt.com

# Server Configuration
PORT=4000
NODE_ENV=development

# Cloudinary Configuration (for file uploads)
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Groq AI Configuration (for AI Tutor)
GROQ_API_KEY=your-groq-api-key-here

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# Frontend URL (for payment callbacks)
FRONTEND_URL=http://localhost:3000

# Webhook URL (Set this in your Paystack dashboard)
# WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/paystack

# AWS S3 Configuration (for image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-s3-bucket-name
